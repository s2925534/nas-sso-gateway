# NAS SSO Gateway — environment configuration
#
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Generate strong secrets with, e.g.:
#   openssl rand -base64 48
#
# See docs/security.md for secret-generation guidance and
# docs/architecture.md for what SSO_BASE_PATH controls.

# --- Hostname / routing -----------------------------------------------------
# Public hostname exposure is handled entirely outside this repo, by whatever
# reverse-proxy/tunnel/deployer tooling you choose (or none, for local-only
# use). This repo never talks to Cloudflare/DNS directly — see
# docs/deployer-integration.md.
SSO_DOMAIN=auth.example.com
SSO_EXTERNAL_URL=https://auth.example.com

# --- Persistent storage ------------------------------------------------------
# Never hardcode a Synology volume path (e.g. /volume1/...) here or in any
# script. When run manually, point this at any persistent local folder. When
# deployed via external tooling, let that tooling decide the real path.
SSO_BASE_PATH=./data/sso

# --- Local bind / port -------------------------------------------------------
# LAN-only/local testing may use 0.0.0.0. Only the authentik web port is ever
# published — Postgres and Redis are never bound to the host.
SSO_HTTP_PORT=9000
SSO_BIND_HOST=0.0.0.0

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=change-me-generate-a-secure-password
# authentik's own view of the same DB credentials (kept equal to the values
# above in the MVP; authentik reads these under its own env var names).
AUTHENTIK_POSTGRES_PASSWORD=change-me-generate-a-secure-password

# --- Redis ----------------------------------------------------------------
REDIS_HOST=redis

# --- authentik core -----------------------------------------------------------
AUTHENTIK_SECRET_KEY=change-me-generate-a-long-random-secret
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me-generate-a-secure-password
# Optional: only needed if you want a pre-provisioned API token for automation.
AUTHENTIK_BOOTSTRAP_TOKEN=

# Pinned to a specific stable release rather than a floating tag — see
# docs/security-hardening.md ("Image Upgrade Procedure") before bumping this.
AUTHENTIK_TAG=2026.5.4

# --- Deployment mode / exposure -----------------------------------------------
# local_only        = no intent to expose publicly (default, safest)
# lan_only          = reachable on the local network only
# deployer_managed  = fronted by an external deployment tool for public
#                      exposure (any tool — e.g. a deployer script, Traefik,
#                      Cloudflare Tunnel; this repo doesn't require a
#                      specific one). REVERSE_PROXY_PROVIDER below names which
#                      kind you're using: deployer_managed | traefik |
#                      cloudflare_tunnel | manual | none.
DEPLOY_MODE=local_only
PUBLIC_EXPOSURE=false
REVERSE_PROXY_PROVIDER=deployer_managed

# --- Optional admin access notes ----------------------------------------------
# Documents whether Tailscale is expected to be used for admin access to this
# service instead of/alongside public exposure. Informational only in the MVP
# — no automation in this repo reads this beyond documentation purposes.
TAILSCALE_ADMIN_ACCESS=true

# --- External-tooling example (commented out) ----------------------------------
# Once your chosen external tooling (a deployer script, Traefik, Cloudflare
# Tunnel — whatever you use) is routing a real hostname to this service, set
# SSO_DOMAIN/SSO_EXTERNAL_URL to your own domain, e.g.:
# SSO_DOMAIN=auth.example.com
# SSO_EXTERNAL_URL=https://auth.example.com
# REVERSE_PROXY_PROVIDER=deployer_managed
