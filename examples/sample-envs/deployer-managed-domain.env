# Sample .env — deployer-managed public domain (auth.veloso.dev)
#
# This example assumes ../synology-site-deployer has already been configured
# to route auth.veloso.dev -> this container's SSO_BIND_HOST:SSO_HTTP_PORT.
# This repo still does not talk to Cloudflare/DNS itself — see
# docs/deployer-integration.md.
#
# Copy relevant values into your real .env. Generate real secrets — see
# docs/security.md. Never commit the real .env.

SSO_DOMAIN=auth.veloso.dev
SSO_EXTERNAL_URL=https://auth.veloso.dev
SSO_BASE_PATH=/path/managed/by/deployer/sso

SSO_HTTP_PORT=9000
SSO_BIND_HOST=0.0.0.0

POSTGRES_DB=authentik
POSTGRES_USER=authentik
POSTGRES_PASSWORD=change-me-generate-a-secure-password
AUTHENTIK_POSTGRES_PASSWORD=change-me-generate-a-secure-password

REDIS_HOST=redis

AUTHENTIK_SECRET_KEY=change-me-generate-a-long-random-secret
AUTHENTIK_BOOTSTRAP_EMAIL=admin@veloso.dev
AUTHENTIK_BOOTSTRAP_PASSWORD=change-me-generate-a-secure-password
AUTHENTIK_BOOTSTRAP_TOKEN=

AUTHENTIK_TAG=latest

DEPLOY_MODE=deployer_managed
PUBLIC_EXPOSURE=true
REVERSE_PROXY_PROVIDER=deployer_managed
TAILSCALE_ADMIN_ACCESS=true
